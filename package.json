{
  "name": "memo-grafter",
  "version": "0.2.6",
  "description": "Structured conversational memory for LLM chatbot applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayhemking007/memo-grafter.git"
  },
  "homepage": "https://github.com/mayhemking007/memo-grafter",
  "bugs": {
    "url": "https://github.com/mayhemking007/memo-grafter/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "USER_GUIDE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:core": "tsx --env-file=.env tests/core/run.ts",
    "test:fleet": "tsx --env-file=.env tests/fleet/run.ts"
  },
  "keywords": [
    "llm",
    "memory",
    "chatbot",
    "rag",
    "knowledge-graph",
    "langchain",
    "openai"
  ],
  "author": "Sarthak Chaturvedi <sarthakchat2018@gmail.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@google/genai": "^0.15.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "openai": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@google/genai": "^0.15.0",
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
